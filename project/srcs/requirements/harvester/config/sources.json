{
	"usda" : {
		"name": "usda Plants Database",
		"base_url": "https://plants.usda.gov",
		"base_url_api": "https://plantsservices.sc.egov.usda.gov",
		"endpoints": {
			"search_api":  "/api/characteristicSearchResults",
			"plant_traits_api": "/api/PlantProfile?symbol={symbol}",
			"plant_characteristics_api": "/api/PlantCharacteristics/{symbol}",
			"plant_traits": "/plant-profile/{symbol}",
			"plant_characteristics": "/plant-profile/{symbol}/characteristics"
		},
		"selectors": {
			"plant_list_links": "table tbody tr th[scope='row'] a",
			"trait_table_rows": "tr"
		},
		"rate_limit": {
			"requests_per_second": 60,
			"concurrent_requests": 3 
		}
	},
	"trefle" : {
		"name": "trefle Plant Database",
		"base_url": "https://trefle.io",
		"base_url_api": "https://trefle.io",
		"endpoints": {
			"plant_list": "/api/v1/plants?token={token}&order[scientific_name]=asc&page=",
			"plant_detail": "/api/v1/species/{slug}?token={token}"
		},
		"rate_limit": {
			"requests_per_second": 1,
			"concurrent_requests": 1 
		}
	}

}
